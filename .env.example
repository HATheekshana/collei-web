# MongoDB Atlas connection string (free M0 cluster)
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/collei?retryWrites=true&w=majority
MONGODB_URI=

# Admin login for the /admin panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Long random string used to sign admin login cookies (any long random text)
JWT_SECRET=change-this-to-a-long-random-string

# Optional: ImgBB API key (free, no billing) so the admin panel can upload
# images directly instead of pasting URLs. Get one free at https://api.imgbb.com/
IMGBB_API_KEY=
